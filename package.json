{
  "name": "eventuate",
  "version": "1.15.2",
  "description": "Extracts information from parkrun results pages for inclusion in reports.",
  "keywords": [
    "parkrun",
    "firefox",
    "web",
    "extension"
  ],
  "homepage": "https://github.com/johnsyweb/eventuate#readme",
  "bugs": {
    "url": "https://github.com/johnsyweb/eventuate/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnsyweb/eventuate.git"
  },
  "license": "MIT",
  "author": "Pete Johns",
  "scripts": {
    "build": "webpack && webpack --config webpack.bookmarklet.config.js && webpack --config webpack.userscript.config.js",
    "build:watch": "webpack --watch",
    "build:userscript:watch": "webpack --config webpack.userscript.config.js --watch",
    "build:bookmarklet:watch": "webpack --config webpack.bookmarklet.config.js --watch",
    "changelog": "conventional-changelog -i CHANGELOG.md -s",
    "commit": "cz",
    "commitlint": "commitlint --edit",
    "docs:build": "pnpm build && cd docs && bundle exec jekyll build",
    "docs:install": "pnpm build && cd docs && bundle install",
    "docs:serve": "pnpm build && cd docs && bundle exec jekyll serve",
    "lighthouse": "tsx script/run-lighthouse.ts",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint . && pnpm format:check",
    "package": "pnpm lint && pnpm build && pnpm web-ext:lint && pnpm web-ext:build && pnpm repack-for-chromium",
    "prepare": "husky",
    "release": "semantic-release",
    "repack-for-chromium": "bash './script/repack-for-chromium'",
    "screenshots": "ts-node script/generate-screenshots.ts",
    "start": "web-ext run -v -u https://www.parkrun.com.au/brimbank/results/latestresults/",
    "test": "jest",
    "version": "pnpm changelog && git add CHANGELOG.md",
    "web-ext:build": "web-ext build -o",
    "web-ext:lint": "web-ext lint"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "commitizen": "^4.3.1",
    "conventional-changelog": "^7.2.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lighthouse": "^13.1.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.2",
    "puppeteer": "^24.40.0",
    "semantic-release": "^25.0.3",
    "serve": "^14.2.6",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "web-ext": "^10.1.0",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2"
  },
  "pnpm": {
    "overrides": {
      "basic-ftp": "5.2.2",
      "lodash": "4.18.1",
      "lodash-es": "4.18.1",
      "@actions/http-client>undici": "6.24.1",
      "@semantic-release/github>undici": "7.24.8",
      "tinyglobby>picomatch": "4.0.4",
      "fdir>picomatch": "4.0.4",
      "external-editor>tmp": "0.2.5"
    }
  },
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=24.10.0",
    "pnpm": ">=10.5.2"
  },
  "webExt": {
    "verbose": true,
    "ignoreFiles": [
      "*.config.js",
      ".tool-versions",
      ".web-extension-id",
      "CODE_OF_CONDUCT.md",
      "Dockerfile",
      "LICENSE.txt",
      "README.md",
      "amo.json",
      "assets",
      "chromium*",
      "docs/**/*",
      "eslint.config.mjs",
      "jest.config.ts",
      "package.json",
      "pnpm-lock.yaml",
      "script",
      "src",
      "target",
      "test",
      "tsconfig.json"
    ],
    "sign": {
      "channel": "listed"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "./script/release \"${nextRelease.version}\""
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json",
            "manifest.json",
            "amo.json",
            "docs/**/*"
          ],
          "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes.split('\\n').slice(0, 3).join('\\n')}"
        }
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "path": "web-ext-artifacts/*.zip",
              "label": "Firefox Extension"
            },
            {
              "path": "eventuate-chromium.zip",
              "label": "Chromium Extension"
            },
            {
              "path": "docs/eventuate.user.js",
              "label": "Userscript"
            },
            {
              "path": "docs/bookmarklet/index.md",
              "label": "Bookmarklet Installation Page"
            }
          ]
        }
      ]
    ]
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "always",
    "proseWrap": "always"
  }
}
