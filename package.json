{
  "name": "eventuate",
  "version": "1.16.1",
  "description": "Extracts information from parkrun results pages for inclusion in reports.",
  "keywords": [
    "parkrun",
    "firefox",
    "web",
    "extension"
  ],
  "homepage": "https://github.com/johnsyweb/eventuate#readme",
  "bugs": {
    "url": "https://github.com/johnsyweb/eventuate/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnsyweb/eventuate.git"
  },
  "license": "MIT",
  "author": "Pete Johns",
  "scripts": {
    "build": "webpack && webpack --config webpack.bookmarklet.config.js && webpack --config webpack.userscript.config.js",
    "build:watch": "webpack --watch",
    "build:userscript:watch": "webpack --config webpack.userscript.config.js --watch",
    "build:bookmarklet:watch": "webpack --config webpack.bookmarklet.config.js --watch",
    "changelog": "conventional-changelog -i CHANGELOG.md -s",
    "commit": "cz",
    "commitlint": "commitlint --edit",
    "docs:build": "aube run build && cd docs && bundle exec jekyll build",
    "docs:install": "aube run build && cd docs && bundle install",
    "docs:serve": "aube run build && cd docs && bundle exec jekyll serve",
    "lighthouse": "tsx script/lib/run-lighthouse.ts",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint . && aube run format:check",
    "prepare": "husky",
    "release": "semantic-release",
    "repack-for-chromium": "bash './script/lib/repack-for-chromium'",
    "screenshots": "ts-node script/lib/generate-screenshots.ts",
    "start": "web-ext run -v -u https://www.parkrun.com.au/brimbank/results/latestresults/",
    "test:units": "jest",
    "version": "aube run changelog && git add CHANGELOG.md",
    "web-ext:build": "web-ext build -o",
    "web-ext:lint": "web-ext lint"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "commitizen": "^4.3.2",
    "conventional-changelog": "^7.2.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lighthouse": "^13.4.0",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "puppeteer": "^25.2.0",
    "semantic-release": "^25.0.5",
    "serve": "^14.2.6",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "web-ext": "^10.4.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "packageManager": "aube@1.25.1",
  "engines": {
    "node": ">=24.10.0"
  },
  "webExt": {
    "verbose": true,
    "ignoreFiles": [
      "*.config.js",
      "mise.toml",
      ".web-extension-id",
      "CODE_OF_CONDUCT.md",
      "Dockerfile",
      "LICENSE.txt",
      "README.md",
      "amo.json",
      "assets",
      "chromium*",
      "docs/**/*",
      "eslint.config.mjs",
      "jest.config.ts",
      "package.json",
      "aube-lock.yaml",
      "script",
      "src",
      "target",
      "test",
      "tsconfig.json"
    ],
    "sign": {
      "channel": "listed"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "./script/lib/release \"${nextRelease.version}\""
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json",
            "manifest.json",
            "amo.json",
            "docs/**/*"
          ],
          "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes.split('\\n').slice(0, 3).join('\\n')}"
        }
      ],
      [
        "@semantic-release/github",
        {
          "successComment": false,
          "failComment": false,
          "releasedLabels": false,
          "assets": [
            {
              "path": "web-ext-artifacts/*.zip",
              "label": "Firefox Extension"
            },
            {
              "path": "eventuate-chromium.zip",
              "label": "Chromium Extension"
            },
            {
              "path": "docs/eventuate.user.js",
              "label": "Userscript"
            },
            {
              "path": "docs/bookmarklet/index.md",
              "label": "Bookmarklet Installation Page"
            }
          ]
        }
      ]
    ]
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "always",
    "proseWrap": "always"
  }
}
